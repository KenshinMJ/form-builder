{
  "name": "form-builder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "build": "next build",
    "build-storybook": "storybook build",
    "dev": "next dev",
    "dev:local:db:up": "docker compose -f docker-compose.local.yml up -d",
    "dev:local:db:setup": "bun run scripts/setup-local-db.ts",
    "dev:local:next": "APP_ENV=local next dev",
    "dev:local": "bun run dev:local:db:up && bun run dev:local:db:setup && bun run dev:local:next",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "sst:dev": "sst dev --stage dev",
    "sst:deploy": "sst deploy --stage prod",
    "sst:remove": "sst remove --stage prod"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1089.0",
    "@aws-sdk/lib-dynamodb": "^3.1089.0",
    "@base-ui/react": "^1.6.0",
    "@formio/js": "^5.4.2",
    "@formio/react": "^6.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "shadcn": "^4.13.0",
    "sst": "^4.17.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/nextjs-vite": "^10.5.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-storybook": "^10.5.2",
    "playwright": "^1.61.1",
    "storybook": "^10.5.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
